# --- VCS / CI ---
.git
.gitignore
.github

# --- Dependencies & build outputs (rebuilt inside the image) ---
node_modules
.next
out
dist
build
coverage

# --- Local databases (the container uses its own volume-mounted DB) ---
*.db
*.db-journal
*.sqlite
*.sqlite3
prisma/dev.db
prisma/*.db
prisma/*.db-journal

# --- Secrets & env (never bake into the image) ---
.env
.env.*
!.env.example

# --- Local uploads (persisted via a Docker volume at runtime) ---
public/uploads/*
!public/uploads/.gitkeep

# --- Docker / compose (not needed inside the image) ---
Dockerfile
.dockerignore
docker-compose*.yml

# --- Logs, archives, editor & OS junk ---
*.log
npm-debug.log*
*.tar
*.tar.gz
*.tgz
*.zip
.DS_Store
Thumbs.db
.vscode
.idea
*.swp

# --- Tests & misc local files ---
.eslintcache
*.local
