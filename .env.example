# =============================================================================
# Portfolio Tracker - Environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# --- Database (SQLite) -------------------------------------------------------
# Local file database (no server needed). Creates prisma/dev.db.
DATABASE_URL="file:./dev.db"

# --- NextAuth / Auth.js ------------------------------------------------------
# The canonical URL of your app (no trailing slash).
NEXTAUTH_URL="http://localhost:3000"
# Secret used to sign session JWTs and CSRF tokens.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-generate-with-openssl-rand-base64-32"

# --- Token encryption --------------------------------------------------------
# 32-byte key (base64 or 64-char hex) used for AES-256-GCM encryption of broker
# API tokens at rest. Generate with: openssl rand -base64 32
ENCRYPTION_KEY="replace-me-generate-with-openssl-rand-base64-32"

# --- Background price refresh (cron) ----------------------------------------
# Shared secret required to call POST /api/cron/refresh from an external
# scheduler (system cron, GitHub Actions, Vercel Cron, etc.).
CRON_SECRET="replace-me-generate-with-openssl-rand-base64-32"

# --- Avatar storage ----------------------------------------------------------
# "local"  -> stores uploaded avatars under ./public/uploads (dev friendly)
# "dataurl"-> stores avatars inline as data URLs in the database (no FS needed)
AVATAR_STORAGE_DRIVER="local"

# --- Market data / FX provider (optional tuning) -----------------------------
# Minimum seconds between automatic provider refreshes (rate-limit guard).
PRICE_MIN_REFRESH_SECONDS="60"

# --- Trading 212 -------------------------------------------------------------
# Users enter their own API key + secret in-app; these only set the API base URLs.
TRADING212_LIVE_BASE_URL="https://live.trading212.com"
TRADING212_DEMO_BASE_URL="https://demo.trading212.com"
